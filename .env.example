# Browser / React SDK — must be the Client-side ID from LaunchDarkly (Test environment).
# In the UI: Project → Environments → Test → copy "Client-side ID" for JavaScript.
# Do NOT use the Server-side SDK key here (those start with sdk-). Using sdk-* causes 401 / "Environment not found".
NEXT_PUBLIC_LD_CLIENT_KEY='<INSERT CLIENT-SIDE ID HERE>'

# Server-side only (Node SDK). Never expose in NEXT_PUBLIC_* or commit real keys.
LD_SDK_KEY='<INSERT SDK KEY HERE>'
